spring:
  datasource:
    password: CHANGE_ME_POSTGRES_PASSWORD

jwt:
  secret: CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# Analyse IA des tickets (OpenAI ou API compatible)
ocr:
  ai:
    enabled: false
    api-key: CHANGE_ME_OPENAI_API_KEY
